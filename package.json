{
  "name": "qingping-desktop-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "青萍桌面助手：清新简约的任务、专注、回顾与计划伴侣。",
  "author": "QingPing contributors",
  "license": "MIT",
  "homepage": "https://github.com/Xueyouing/QingPing",
  "repository": {
    "type": "git",
    "url": "https://github.com/Xueyouing/QingPing.git"
  },
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check app.js && node --check electron-main.js && node --check preload.js",
    "dist:win": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg --universal",
    "dist:linux": "electron-builder --linux AppImage --x64",
    "pack:win": "electron-builder --win dir"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.qingping.desktop",
    "productName": "青萍",
    "asar": true,
    "compression": "maximum",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "app.js",
      "electron-main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "assets/qingping-bubble-icon.png",
      "artifactName": "QingPing-V${version}-Windows-${arch}-Setup.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "assets/qingping-lily-clock.png",
      "category": "public.app-category.productivity",
      "artifactName": "QingPing-V${version}-macOS-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/qingping-lily-clock.png",
      "category": "Utility",
      "synopsis": "清新简约的桌面效率助手",
      "artifactName": "QingPing-V${version}-Linux-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "青萍",
      "artifactName": "QingPing-V${version}-Windows-${arch}-Setup.${ext}"
    }
  }
}
